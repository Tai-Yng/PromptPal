{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PromptPal",
  "version": "1.0.0",
  "identifier": "com.promptpal.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5176",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "pet",
        "title": "PromptPal",
        "url": "/?window=pet",
        "width": 120,
        "height": 200,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": true
      },
      {
        "label": "panel",
        "title": "PromptPal - Prompt 管理",
        "url": "/?window=panel",
        "width": 780,
        "height": 760,
        "minWidth": 560,
        "minHeight": 520,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"]
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  }
}
